# DevOps Maturity Assessment Environment Variables

# Session Secret Key (change this to a random string for production)
SESSION_SECRET_KEY=devops-maturity-secret-change-me

# OAuth Configuration
# To enable Google OAuth login, create OAuth credentials at:
# https://console.developers.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# To enable GitHub OAuth login, create OAuth app at:
# https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# Notes:
# - For Google OAuth, authorized redirect URI should be: http://localhost:8000/auth/callback/google
# - For GitHub OAuth, authorization callback URL should be: http://localhost:8000/auth/callback/github
# - For production, replace localhost:8000 with your domain

# ── AI-powered auto-assessment ────────────────────────────────────────────────
# API keys for the AI providers used by `devops-maturity assess --auto`.
# Only the key for the provider you select is required.

# OpenAI  (--ai openai)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic  (--ai anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini  (--ai gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama runs locally; no API key is needed.
# Set OLLAMA_URL if your server is not at the default http://localhost:11434
# OLLAMA_URL=http://localhost:11434

# ── Repository tokens (optional – needed only for private repositories) ───────
# Personal access tokens for each git provider.
# Can also be passed via --repo-token on the command line.

GITHUB_TOKEN=your-github-personal-access-token-here
GITLAB_TOKEN=your-gitlab-personal-access-token-here
BITBUCKET_TOKEN=your-bitbucket-app-password-here

